{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,

    /* Linting */
    "strict": true,
    "allowJs": false,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    /* Customization */
    "sourceMap": true,
    "paths": {
      "@/*": ["./src/*"],
      // pinia 4.0.x의 package.json "exports"에 types 조건이 누락되어
      // moduleResolution:"bundler"에서 타입 선언을 찾지 못하는 문제 우회(TS7016).
      // pinia가 exports에 types 조건을 복구하면 이 항목은 제거 가능.
      "pinia": ["./node_modules/pinia/dist/pinia.d.ts"]
    },
    "types": ["vuetify", "vite/client", "vue"],

    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"],
  "exclude": ["node_modules", "dist"]
}
